# This is the single deployment dotenv file.
# Production path:
#   /data/workspace/sage-wiki-bridge-wxo/.env
#
# The systemd unit passes this file directly to the binary with --env-file.
# scripts/bridgectl.sh is only a thin compatibility wrapper around the same binary commands.
# Keep secrets here. Add BRIDGE_* overrides only when the built-in default is not right
# for this deployment.

# Required when OpenResty does not proxy to the built-in 127.0.0.1:8080 default.
BRIDGE_BIND_ADDR=127.0.0.1:8087

# Required when WeChat is configured to call /wechat instead of /wechat/callback.
BRIDGE_WECHAT_CALLBACK_PATH=/wechat

# Required output directory for sage-wiki compile --watch.
BRIDGE_SAGE_WIKI_SOURCE_DIR=/data/workspace/sage-wiki/source

# Required when the WeChat Official Account platform uses encrypted callback mode.
BRIDGE_WECHAT_ENCRYPTED_CALLBACK_ENABLED=true

# Optional operational overrides. Leave commented to use built-in defaults.
# BRIDGE_DATABASE_URL=sqlite://data/bridge.sqlite3
# BRIDGE_RAW_ARCHIVE_DIR=data/raw
# BRIDGE_PROCESSED_ARTIFACT_DIR=data/processed
# BRIDGE_RUST_LOG=info,sage_wiki_bridge=debug
# BRIDGE_WHITELIST_JOIN_COMMAND=/sage-wiki-join
# BRIDGE_ADMIN_BASE_PATH=/admin

WECHAT_TOKEN=replace-with-wechat-callback-token
WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
WECHAT_ENCODING_AES_KEY=replace-with-wechat-encoding-aes-key
WECHAT_ADMIN_OPENIDS=openid-admin-1,openid-admin-2

ADMIN_VIEW_KEY=replace-with-admin-view-key

TENCENT_LBS_KEY=replace-with-tencent-lbs-key
JINA_API_KEY=replace-with-jina-api-key
GEMINI_API_KEY=replace-with-gemini-api-key
