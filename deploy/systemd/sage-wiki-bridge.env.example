# This file is loaded explicitly by the systemd unit:
#   EnvironmentFile=/etc/sage-wiki-bridge.env
#
# BRIDGE_* variables are deployment/runtime knobs consumed by the unit.
# Non-BRIDGE variables are secrets and app identifiers consumed by the binary
# through --env-file.

BRIDGE_BIN_PATH=/opt/sage-wiki-bridge/bin/sage-wiki-bridge
BRIDGE_CONFIG_ENV_FILE=/etc/sage-wiki-bridge.env

BRIDGE_BIND_ADDR=127.0.0.1:8080
BRIDGE_DATABASE_URL=sqlite:///opt/sage-wiki-bridge/data/bridge.sqlite3
BRIDGE_DATABASE_MAX_CONNECTIONS=4
BRIDGE_DATABASE_MIN_CONNECTIONS=1
BRIDGE_RAW_ARCHIVE_DIR=/opt/sage-wiki-bridge/data/raw
BRIDGE_RAW_ARCHIVE_FULL=true
BRIDGE_PROCESSED_ARTIFACT_DIR=/opt/sage-wiki-bridge/data/processed
BRIDGE_SAGE_WIKI_SOURCE_DIR=/opt/sage-wiki/source
BRIDGE_WECHAT_CALLBACK_PATH=/wechat/callback
BRIDGE_WECHAT_ENCRYPTED_CALLBACK_ENABLED=false
BRIDGE_HONEYPOT_REPLY_ENABLED=false
BRIDGE_HONEYPOT_REPLY_TEXT="Message received."
BRIDGE_WORKER_ENABLED=true
BRIDGE_WORKER_ID=worker-main
BRIDGE_APP_VERSION=0.1.0
BRIDGE_WORKER_INTERVAL_MS=1000
BRIDGE_WORKER_PROCESSING_TIMEOUT_SECONDS=900
BRIDGE_WORKER_RETRY_BASE_SECONDS=10
BRIDGE_WORKER_RETRY_MAX_SECONDS=300
BRIDGE_HTTP_TIMEOUT_SECONDS=30
BRIDGE_REQUEST_BODY_LIMIT_BYTES=2097152
BRIDGE_HEALTHZ_PATH=/healthz
BRIDGE_READYZ_PATH=/readyz
BRIDGE_WECHAT_API_BASE=https://api.weixin.qq.com
BRIDGE_WECHAT_TOKEN_REFRESH_SKEW_SECONDS=300
BRIDGE_ADMIN_BASE_PATH=/admin
BRIDGE_WHITELIST_JOIN_COMMAND=
BRIDGE_ADMIN_DEFAULT_PER_PAGE=20
BRIDGE_ADMIN_MAX_PER_PAGE=100
BRIDGE_MAX_MEDIA_BYTES=20971520
BRIDGE_GEMINI_ENDPOINT_BASE=https://generativelanguage.googleapis.com
BRIDGE_GEMINI_MODEL=gemini-2.5-flash
BRIDGE_GEMINI_MAX_INLINE_BYTES=18874368
BRIDGE_LLM_IMAGE_SYSTEM_PROMPT="Describe this image for a personal knowledge base."
BRIDGE_LLM_VOICE_SYSTEM_PROMPT="Transcribe and summarize this voice message."
BRIDGE_LLM_VIDEO_SYSTEM_PROMPT="Summarize this video for a personal knowledge base."
BRIDGE_TENCENT_LBS_ENDPOINT=https://apis.map.qq.com/ws/geocoder/v1/
BRIDGE_TENCENT_LBS_GET_POI=true
BRIDGE_TENCENT_LBS_RADIUS_METERS=500
BRIDGE_JINA_READER_ENDPOINT=https://r.jina.ai

WECHAT_TOKEN=replace-with-wechat-callback-token
WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
# WECHAT_APPID and WECHAT_APPSECRET are accepted as aliases.
WECHAT_ENCODING_AES_KEY=
WECHAT_ADMIN_OPENIDS=openid-admin-1,openid-admin-2

ADMIN_VIEW_KEY=replace-with-admin-view-key

TENCENT_LBS_KEY=replace-with-tencent-lbs-key
JINA_API_KEY=
GEMINI_API_KEY=replace-with-gemini-api-key
