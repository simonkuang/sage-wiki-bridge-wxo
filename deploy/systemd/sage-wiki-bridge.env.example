APP_BIND_ADDR=127.0.0.1:8080
DATABASE_URL=sqlite:///opt/sage-wiki-bridge/data/bridge.sqlite3
RAW_ARCHIVE_DIR=/opt/sage-wiki-bridge/data/raw
RAW_ARCHIVE_FULL=true
PROCESSED_ARTIFACT_DIR=/opt/sage-wiki-bridge/data/processed
SAGE_WIKI_SOURCE_DIR=/opt/sage-wiki/source
WECHAT_CALLBACK_PATH=/wechat/callback
HONEYPOT_REPLY_ENABLED=false
HONEYPOT_REPLY_TEXT=Message received.
WORKER_ENABLED=true
WORKER_INTERVAL_MS=1000
HTTP_TIMEOUT_SECONDS=30

WECHAT_TOKEN=replace-with-wechat-callback-token
WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
WECHAT_ENCODING_AES_KEY=
WECHAT_API_BASE=https://api.weixin.qq.com
WECHAT_OAUTH_AUTHORIZE_BASE=https://open.weixin.qq.com/connect/oauth2/authorize

ADMIN_VIEW_KEY=replace-with-admin-view-key
WHITELIST_JOIN_KEY=replace-with-whitelist-join-key
WHITELIST_JOIN_REDIRECT_URL=https://bridge.example.com/admin/whitelist/join?key=replace-with-whitelist-join-key

TENCENT_LBS_KEY=replace-with-tencent-lbs-key
TENCENT_LBS_ENDPOINT=https://apis.map.qq.com/ws/geocoder/v1/
TENCENT_LBS_GET_POI=true
TENCENT_LBS_RADIUS_METERS=500

JINA_API_KEY=
JINA_READER_ENDPOINT=https://r.jina.ai

GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_ENDPOINT_BASE=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_INLINE_BYTES=18874368
MAX_MEDIA_BYTES=20971520

RUST_LOG=info,sage_wiki_bridge=debug
