[Unit]
Description=sage-wiki WeChat Official Account bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sagewiki
Group=sagewiki
WorkingDirectory=/data/workspace/sage-wiki-bridge-wxo
ExecStart=/usr/local/bin/sage-wiki-bridge --env-file /data/workspace/sage-wiki-bridge-wxo/.env
Restart=on-failure
RestartSec=5s
TimeoutStopSec=20s

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/data/workspace/sage-wiki-bridge-wxo/data /data/workspace/sage-wiki/source

MemoryAccounting=true
MemoryMax=256M

[Install]
WantedBy=multi-user.target
