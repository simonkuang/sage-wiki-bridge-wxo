[Unit]
Description=sage-wiki WeChat Official Account bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sagewiki
Group=sagewiki
WorkingDirectory=/opt/sage-wiki-bridge
ExecStart=/opt/sage-wiki-bridge/bin/sage-wiki-bridge \
  --env-file /etc/sage-wiki-bridge.env \
  --bind-addr 127.0.0.1:8080 \
  --database-url sqlite:///opt/sage-wiki-bridge/data/bridge.sqlite3 \
  --database-max-connections 4 \
  --database-min-connections 1 \
  --raw-archive-dir /opt/sage-wiki-bridge/data/raw \
  --raw-archive-full true \
  --processed-artifact-dir /opt/sage-wiki-bridge/data/processed \
  --sage-wiki-source-dir /opt/sage-wiki/source \
  --wechat-callback-path /wechat/callback \
  --wechat-encrypted-callback-enabled false \
  --honeypot-reply-enabled false \
  --honeypot-reply-text "Message received." \
  --worker-enabled true \
  --worker-id worker-main \
  --bridge-version 0.1.0 \
  --worker-interval-ms 1000 \
  --worker-processing-timeout-seconds 900 \
  --worker-retry-base-seconds 10 \
  --worker-retry-max-seconds 300 \
  --http-timeout-seconds 30 \
  --request-body-limit-bytes 2097152 \
  --healthz-path /healthz \
  --readyz-path /readyz \
  --wechat-api-base https://api.weixin.qq.com \
  --wechat-oauth-authorize-base https://open.weixin.qq.com/connect/oauth2/authorize \
  --wechat-token-refresh-skew-seconds 300 \
  --admin-base-path /admin \
  --whitelist-join-redirect-url "" \
  --admin-default-per-page 20 \
  --admin-max-per-page 100 \
  --max-media-bytes 20971520 \
  --gemini-endpoint-base https://generativelanguage.googleapis.com \
  --gemini-model gemini-2.5-flash \
  --gemini-max-inline-bytes 18874368 \
  --llm-image-system-prompt "Describe this image for a personal knowledge base." \
  --llm-voice-system-prompt "Transcribe and summarize this voice message." \
  --llm-video-system-prompt "Summarize this video for a personal knowledge base." \
  --tencent-lbs-endpoint https://apis.map.qq.com/ws/geocoder/v1/ \
  --tencent-lbs-get-poi true \
  --tencent-lbs-radius-meters 500 \
  --jina-reader-endpoint https://r.jina.ai \
  --rust-log info,sage_wiki_bridge=debug
Restart=on-failure
RestartSec=5s
TimeoutStopSec=20s

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/sage-wiki-bridge/data /opt/sage-wiki/source

MemoryAccounting=true
MemoryMax=256M

[Install]
WantedBy=multi-user.target
